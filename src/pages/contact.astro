---
import Layout from '../layouts/Layout.astro';

const googleMapsUrl = 'https://www.google.com/maps/dir/?api=1&destination=3825+Washington+Rd+McMurray+PA+15317';
---

<Layout title="Contact | Bado's Cucina" description="Contact Bado's Cucina. Reservations recommended. 3825 Washington Rd, McMurray, PA 15317. Call 724.942.3904.">

  <section class="contact-hero">
    <div class="container">
      <h1 class="reveal">Contact</h1>
      <hr class="divider reveal" />
    </div>
  </section>

  <section class="contact-grid section">
    <div class="container">
      <div class="contact-grid__layout">

        <!-- Hours -->
        <div class="contact-card reveal">
          <h2>Hours</h2>
          <hr class="divider" />
          <dl class="hours-list">
            <div class="hours-row">
              <dt>Tuesday &ndash; Thursday</dt>
              <dd>5:00 &ndash; 10:00 pm</dd>
            </div>
            <div class="hours-row">
              <dt>Friday & Saturday</dt>
              <dd>5:00 &ndash; 11:00 pm</dd>
            </div>
            <div class="hours-row">
              <dt>Sunday & Monday</dt>
              <dd>Closed for Private Parties</dd>
            </div>
          </dl>
          <p class="hours-note">Reservations recommended</p>
        </div>

        <!-- Reservations -->
        <div class="contact-card reveal">
          <h2>Reservations</h2>
          <hr class="divider" />
          <p class="contact-card__text">
            Call to reserve your table. Walk-ins welcome when available.
          </p>
          <address class="contact-address">
            <a href="tel:7249423904" class="contact-phone">724.942.3904</a>
          </address>
        </div>

        <!-- Location -->
        <div class="contact-card contact-card--wide reveal">
          <h2>Find Us</h2>
          <hr class="divider" />
          <div class="location-layout">
            <a href={googleMapsUrl} target="_blank" rel="noopener noreferrer" class="map-link">
              <div class="map-wrap">
