                  <text x="532.6" y="120.0" font-size="9" fill="oklch(0.42 0.015 60)" text-anchor="middle" transform="rotate(-64.7 532.6 120.0)">High Street</text>
                  <text x="310.4" y="260.9" font-size="9" fill="oklch(0.42 0.015 60)" text-anchor="middle" transform="rotate(82.7 310.4 260.9)">Jones Drive</text>
                  <text x="123.9" y="178.2" font-size="9" fill="oklch(0.42 0.015 60)" text-anchor="middle" transform="rotate(-66.6 123.9 178.2)">Moore Drive</text>
                  <text x="105.7" y="0.6" font-size="9" fill="oklch(0.42 0.015 60)" text-anchor="middle" transform="rotate(58.6 105.7 0.6)">Acorn Lane</text>
                  <text x="243.4" y="127.6" font-size="11" fill="oklch(0.50 0.02 60)" text-anchor="middle" transform="rotate(71.7 243.4 127.6)">Old Oak Road</text>
                  <text x="352.8" y="152.8" font-size="9" fill="oklch(0.42 0.015 60)" text-anchor="middle" transform="rotate(22.3 352.8 152.8)">Pleasant Avenue</text>
                  <text x="136.1" y="265.5" font-size="11" fill="oklch(0.50 0.02 60)" text-anchor="middle" transform="rotate(24.3 136.1 265.5)">West McMurray Road</text>
                  <text x="354.8" y="159.3" font-size="9" fill="oklch(0.42 0.015 60)" text-anchor="middle" transform="rotate(72.4 354.8 159.3)">Meadow Street</text>
                  <text x="158.8" y="353.6" font-size="9" fill="oklch(0.42 0.015 60)" text-anchor="middle" transform="rotate(13.7 158.8 353.6)">McConnell Drive</text>
                  <text x="472.5" y="330.7" font-size="9" fill="oklch(0.42 0.015 60)" text-anchor="middle" transform="rotate(-7.0 472.5 330.7)">McNary Street</text>
                  <text x="251.5" y="265.1" font-size="11" fill="oklch(0.50 0.02 60)" text-anchor="middle" transform="rotate(-68.3 251.5 265.1)">Washington Road</text>
                  <text x="268.0" y="325.4" font-size="11" fill="oklch(0.50 0.02 60)" text-anchor="middle" transform="rotate(26.2 268.0 325.4)">East McMurray Road</text>
                  <ellipse cx="300.0" cy="218.0" rx="8" ry="3" fill="oklch(0 0 0 / 0.4)"/>
                  <g transform="translate(290.0,176.0)">
                    <path d="M10 0C4.477 0 0 4.477 0 10c0 7.5 10 18 10 18s10-10.5 10-18C20 4.477 15.523 0 10 0zm0 14a4 4 0 110-8 4 4 0 010 8z" fill="oklch(0.72 0.14 60)"/>
                  </g>
                  <text x="592" y="392" font-size="7" fill="oklch(0.35 0.01 55)" text-anchor="end">&copy; OpenStreetMap contributors</text>
                </svg>
              </div>
              <div class="map-bar">
                <span class="map-bar__name">Bado's Cucina</span>
                <span class="map-bar__address">3825 Washington Rd, McMurray, PA 15317</span>
                <span class="map-bar__cta">Open in Google Maps &rarr;</span>
              </div>
            </a>
          </div>
        </div>

        <!-- Gift Cards -->
        <div class="contact-card reveal">
          <h2>Gift Cards</h2>
          <hr class="divider" />
          <p class="contact-card__text">
            Gift cards are available in amounts between $25 and $250.
            Purchase at the restaurant, by phone, or securely online with PayPal.
          </p>
          <a href="tel:7249423904" class="btn">Order by Phone</a>
        </div>

        <!-- Employment -->
        <div class="contact-card reveal">
          <h2>Employment</h2>
          <hr class="divider" />
          <p class="contact-card__text">
            Interested in part-time employment? Give us a call or stop by the restaurant.
          </p>
          <a href="tel:7249423904" class="contact-phone contact-phone--small">724.942.3904</a>
        </div>

        <!-- Contact Form -->
        <div class="contact-card contact-card--wide reveal">
          <h2>Send a Message</h2>
          <hr class="divider" />
          <form action="https://api.keithkelly.dev/contact/badoscucina" method="POST" class="contact-form">
            <div class="form-row">
              <div class="form-field">
                <label for="contact-name">Name <span class="form-required" aria-label="required">*</span></label>
                <input type="text" id="contact-name" name="name" required autocomplete="name" />
              </div>
              <div class="form-field">
                <label for="contact-email">Email <span class="form-required" aria-label="required">*</span></label>
                <input type="email" id="contact-email" name="email" required autocomplete="email" />
              </div>
            </div>
            <div class="form-field">
              <label for="contact-message">Message <span class="form-required" aria-label="required">*</span></label>
              <textarea id="contact-message" name="message" rows="4" required></textarea>
            </div>
            <button type="submit" class="btn btn--solid">Send Message</button>
          </form>
        </div>

      </div>
    </div>
  </section>

</Layout>

<style>
  .contact-hero {
    padding-top: calc(var(--space-3xl) + 80px);
    padding-bottom: var(--space-xl);
  }

  .contact-hero h1 {
    font-size: clamp(3rem, 2.5rem + 4vw, 7rem);
    font-style: italic;
  }

  /* Grid layout */
  .contact-grid__layout {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-l);
  }

  .contact-card {
    background: var(--color-bg-warm);
    border: 1px solid var(--color-border);
    padding: var(--space-xl);

    & h2 {
      font-size: clamp(1.25rem, 1.1rem + 0.5vw, 1.6rem);
    }
  }

  .contact-card--wide {
    grid-column: 1 / -1;
  }

  .contact-card__text {
    color: var(--color-text-muted);
    margin-bottom: var(--space-m);
  }

  /* Hours */
  .hours-list {
    display: grid;
    gap: var(--space-s);
    margin-bottom: var(--space-m);
  }

  .hours-row {
    display: flex;
    justify-content: space-between;
    gap: var(--space-m);
    padding-bottom: var(--space-s);
    border-bottom: 1px solid var(--color-border);

    & dt {
      font-weight: 400;
    }

    & dd {
      color: var(--color-text-muted);
      text-align: right;
    }
  }

  .hours-note {
    font-family: var(--font-display), Georgia, serif;
    font-style: italic;
    color: var(--color-accent);
    font-size: 0.95rem;
  }

  .contact-address {
    font-style: normal;
  }

  /* Phone link */
  .contact-phone {
    display: block;
    font-family: var(--font-display), Georgia, serif;
    font-size: clamp(1.5rem, 1.25rem + 1vw, 2.25rem);
    font-weight: 400;
    letter-spacing: 0.03em;
    color: var(--color-accent);
    margin-top: var(--space-m);
    transition: color 0.3s;

    &:hover {
      color: var(--color-text);
    }
  }

  .contact-phone--small {
    font-size: clamp(1.2rem, 1rem + 0.5vw, 1.5rem);
  }

  /* Map */
  .location-layout {
    margin-top: var(--space-m);
  }

  .map-link {
    display: block;
    overflow: hidden;
    border: 1px solid var(--color-border);
    transition: transform 0.3s var(--ease-out);

    &:hover {
      transform: scale(1.005);
    }

    &:hover .map-wrap svg {
      transform: scale(1.02);
    }

    &:hover .map-bar__cta {
      color: var(--color-accent);
    }
  }

  .map-wrap {
    overflow: hidden;

    & svg {
      width: 100%;
      height: auto;
      display: block;
      transition: transform 0.4s var(--ease-out);
    }
  }

  .map-bar {
    display: flex;
    align-items: center;
    gap: var(--space-m);
    padding: var(--space-m);
    background: var(--color-bg-card);
    border-top: 1px solid var(--color-border);
  }

  .map-bar__name {
    font-family: var(--font-display), Georgia, serif;
    font-style: italic;
    font-size: 1rem;
    white-space: nowrap;
  }

  .map-bar__address {
    font-size: 0.85rem;
    color: var(--color-text-muted);
    flex: 1;
  }

  .map-bar__cta {
    font-size: 0.8rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-text-muted);
    white-space: nowrap;
    transition: color 0.3s;
  }

  /* Contact form */
  .contact-form {
    display: grid;
    gap: var(--space-m);
  }

  .form-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-m);
  }

  .form-field {
    display: grid;
    gap: var(--space-xs);
  }

  .form-field label {
    font-size: 0.85rem;
    font-weight: 400;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-text-muted);
  }

  .form-required {
    color: var(--color-accent);
  }

  .form-field input,
  .form-field textarea {
    font-family: var(--font-body), system-ui, sans-serif;
    font-size: 1rem;
    color: var(--color-text);
    background: var(--color-bg);
    border: 1px solid var(--color-border);
    padding: 0.75em 1em;
    transition: border-color 0.3s;
    min-height: 44px;

    &:focus {
      outline: none;
      border-color: var(--color-accent);
    }
  }

  .form-field textarea {
    resize: vertical;
    min-height: 120px;
  }

  @media (max-width: 640px) {
    .form-row {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 768px) {
    .contact-grid__layout {
      grid-template-columns: 1fr;
    }

    .map-bar {
      flex-direction: column;
      align-items: flex-start;
      gap: var(--space-xs);
    }
  }
</style>
