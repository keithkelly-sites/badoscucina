---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Menu | Bado's Cucina" description="Seasonal wood-fired menu at Bado's Cucina. Antipasto, handmade pasta, wood-fired meats and seafood, artisan pizzas, and homemade desserts. BYOB welcome.">

  <section class="menu-hero">
    <div class="container">
      <h1 class="menu-hero__title reveal">Menu</h1>
      <p class="menu-hero__sub reveal">Seasonal &middot; Wood-Fired &middot; BYOB</p>
      <hr class="divider reveal" />
      <p class="menu-hero__note reveal">
        We offer a seasonal menu with daily and weekly features.
        Follow us on <a href="https://www.facebook.com/badoswoodoven/" target="_blank" rel="noopener noreferrer">Facebook</a> for
        the latest. BYOB with corkage fee. All prices subject to change.
      </p>
    </div>
  </section>

  <!-- Antipasto & Flatbreads -->
  <section class="menu-course section--tight" id="antipasto">
    <div class="container--narrow">
      <div class="course-header reveal">
        <span class="course-header__italian">Antipasto</span>
        <h2>Starters & Flatbreads</h2>
        <p class="course-header__desc">Traditional start to the meal</p>
      </div>

      <div class="menu-items reveal-stagger">
        <div class="menu-item reveal">
          <h3 class="menu-item__name">"Rustico"</h3>
          <p class="menu-item__desc">Prosciutto, soppressata, capicola, mixed Italian aged cheeses, and Mediterranean olives</p>
        </div>
        <div class="menu-item reveal">
          <h3 class="menu-item__name">"Olivo"</h3>
          <p class="menu-item__desc">Mixed Mediterranean olives, Italian aged cheeses, and warm crusted bread</p>
        </div>
        <div class="menu-item reveal">
          <h3 class="menu-item__name">Fondue</h3>
          <p class="menu-item__desc">Italian aged cheeses with roasted pepper flakes, bread, and fresh fruit</p>
        </div>
        <div class="menu-item reveal">
          <h3 class="menu-item__name">Mushroom Truffle Flatbread</h3>
          <p class="menu-item__desc">Wild mushrooms, cranberries, and parsley with our shallot tapenade</p>
        </div>
        <div class="menu-item reveal">
          <h3 class="menu-item__name">Apple & Pancetta Flatbread</h3>
          <p class="menu-item__desc">With extra virgin olive oil, sauteed onions, goat cheese and sage</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Decorative food image band -->
  <div class="image-band">
    <img src="/images/fondue.jpg" alt="Fondue with bread and herbs" class="image-band__img" loading="lazy" />
    <img src="/images/flatbreads.jpg" alt="Mushroom flatbreads from the wood-fired oven" class="image-band__img" loading="lazy" />
    <img src="/images/pasta.jpg" alt="Handmade pasta with fresh mozzarella" class="image-band__img" loading="lazy" />
  </div>

  <!-- Primi -->
  <section class="menu-course section--tight" id="primi">
    <div class="container--narrow">
      <div class="course-header reveal">
        <span class="course-header__italian">Primi</span>
        <h2>First Course</h2>
        <p class="course-header__desc">Pasta & soup</p>
      </div>

      <div class="menu-items reveal-stagger">
        <div class="menu-item reveal">
          <h3 class="menu-item__name">Homemade Lasagna</h3>
          <p class="menu-item__desc">Weekly selection wood-fired, blended with ricotta and Italian cheeses</p>
        </div>
        <div class="menu-item reveal">
          <h3 class="menu-item__name">Homemade Ricotta Cavatelli</h3>
          <p class="menu-item__desc">Cavatelli pasta with a creamy pancetta and sage sauce, topped with Reggiano cheese and finished in the oven</p>
        </div>
        <div class="menu-item reveal">
          <h3 class="menu-item__name">Pumpkin Gnocchi</h3>
          <p class="menu-item__desc">With vodka sauce</p>
        </div>
        <div class="menu-item reveal">
          <h3 class="menu-item__name">Butternut Squash Ravioli</h3>
          <p class="menu-item__desc">With brown butter and sage</p>
        </div>
        <div class="menu-item reveal">
          <h3 class="menu-item__name">Soup of the Day</h3>
          <p class="menu-item__desc">Ask your server for today's selection</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Secondi -->
  <section class="menu-course menu-course--warm section--tight" id="secondi">
    <div class="container--narrow">
      <div class="course-header reveal">
        <span class="course-header__italian">Secondi</span>
        <h2>Second Course</h2>
        <p class="course-header__desc">Meat, fish, and poultry served with seasonal vegetable</p>
      </div>

      <div class="menu-items reveal-stagger">
        <div class="menu-item reveal">
          <h3 class="menu-item__name">Duck</h3>
          <p class="menu-item__desc">Tender duck breast blackened and wood-fired</p>
        </div>
        <div class="menu-item reveal">
          <h3 class="menu-item__name">Lamb</h3>
          <p class="menu-item__desc">Double chops in a citrus marinade with red wine, mint and rosemary</p>
        </div>
        <div class="menu-item reveal">
          <h3 class="menu-item__name">Bistecca</h3>
          <p class="menu-item__desc">Grass fed New York strip flame grilled, topped with herbed goat cheese and finished with balsamic reduction</p>
        </div>
        <div class="menu-item reveal">
          <h3 class="menu-item__name">Scallops</h3>
          <p class="menu-item__desc">Seasoned and pan seared in our wood-fired oven with lemon butter</p>
        </div>
        <div class="menu-item reveal">
          <h3 class="menu-item__name">Salmon</h3>
          <p class="menu-item__desc">Atlantic salmon, wood fired and topped with a walnut and goat cheese crust, finished with brown butter</p>
        </div>
        <div class="menu-item reveal">
          <h3 class="menu-item__name">Chicken Marsala</h3>
          <p class="menu-item__desc">Two wood-fired chicken breasts with a mushroom and grape marsala sauce</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Food image band 2 -->
  <div class="image-band">
    <img src="/images/lamb-chops.jpg" alt="Wood-fired lamb chops" class="image-band__img" loading="lazy" />
    <img src="/images/soup-wine.jpg" alt="Soup of the day with a glass of wine" class="image-band__img" loading="lazy" />
    <img src="/images/stuffed-pepper.jpg" alt="Stuffed pepper with marinara and melted cheese" class="image-band__img" loading="lazy" />
  </div>

  <!-- Contorni -->
  <section class="menu-course section--tight" id="contorni">
    <div class="container--narrow">
      <div class="course-header reveal">
        <span class="course-header__italian">Contorni</span>
        <h2>Salads & Sides</h2>
        <p class="course-header__desc">Seasonal vegetables and salads</p>
      </div>

      <div class="menu-items reveal-stagger">
        <div class="menu-item reveal">
          <h3 class="menu-item__name">Caesar Salad</h3>
          <p class="menu-item__desc">Wood-fired romaine with prosciutto, tomatoes, croutons and homemade dressing</p>
        </div>
        <div class="menu-item reveal">
          <h3 class="menu-item__name">House Salad</h3>
          <p class="menu-item__desc">Fresh spring mix, tomatoes, shaved parmesan and house balsamic vinaigrette</p>
        </div>
        <div class="menu-item reveal">
          <h3 class="menu-item__name">Portobello Salad</h3>
          <p class="menu-item__desc">Fresh spring mix, pears, crumbled gorgonzola, red onions, and walnuts with pan seared portobello mushrooms and balsamic dressing</p>
        </div>
        <div class="menu-item reveal">
          <h3 class="menu-item__name">Artichokes</h3>
          <p class="menu-item__desc">Stuffed with goat cheese, bread crumbs and herbs, grilled in our wood-fired oven</p>
        </div>
        <div class="menu-item reveal">
          <h3 class="menu-item__name">Banana Pepper</h3>
          <p class="menu-item__desc">Stuffed with sweet sausage and melted provolone</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Pizzas -->
  <section class="menu-course menu-course--warm section--tight" id="pizzas">
    <div class="container--narrow">
      <div class="course-header reveal">
        <span class="course-header__italian">Pizza</span>
        <h2>Wood-Fired Pizzas</h2>
      </div>

      <div class="menu-items reveal-stagger">
        <div class="menu-item reveal">
          <h3 class="menu-item__name">Classico</h3>
          <p class="menu-item__desc">House marinara, mozzarella and provolone</p>
        </div>
        <div class="menu-item reveal">
          <h3 class="menu-item__name">Margherita</h3>
          <p class="menu-item__desc">San Marzano tomatoes, buffalo mozzarella and Pecorino Romano, fresh basil and extra-virgin</p>
        </div>
        <div class="menu-item reveal">
          <h3 class="menu-item__name">Bianco</h3>
          <p class="menu-item__desc">Romano and mozzarella cheeses, bread crumbs, garlic, extra-virgin olive oil and chopped tomatoes</p>
        </div>
        <div class="menu-item reveal">
          <h3 class="menu-item__name">Papa Cucina</h3>
          <p class="menu-item__desc">San Marzano tomatoes, buffalo mozzarella, sweet sauteed onions and oregano</p>
        </div>
        <div class="menu-item reveal">
          <h3 class="menu-item__name">Leopold</h3>
          <p class="menu-item__desc">Vodka sauce, crumbled Italian sausage, artichoke hearts and mozzarella cheese</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Dolce -->
  <section class="menu-course section--tight" id="dolce">
    <div class="container--narrow">
      <div class="course-header reveal">
        <span class="course-header__italian">Dolce</span>
        <h2>Desserts</h2>
      </div>

      <div class="menu-items reveal-stagger">
        <div class="menu-item reveal">
          <h3 class="menu-item__name">Homemade Tiramisu</h3>
          <p class="menu-item__desc">Traditional or seasonal selection</p>
        </div>
        <div class="menu-item reveal">
          <h3 class="menu-item__name">Bread Pudding</h3>
          <p class="menu-item__desc">Daily selection</p>
        </div>
        <div class="menu-item reveal">
          <h3 class="menu-item__name">Wood-Fired Tuscan Toast</h3>
          <p class="menu-item__desc">With pecorino romano on cinnamon toast drizzled with honey</p>
        </div>
        <div class="menu-item reveal">
          <h3 class="menu-item__name">Cannoli</h3>
          <p class="menu-item__desc">With daily selection of fresh ricotta filling</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Dessert image -->
  <div class="image-band image-band--duo">
    <img src="/images/bread-pudding.jpg" alt="Homemade bread pudding" class="image-band__img" loading="lazy" />
    <img src="/images/lasagna.jpg" alt="Homemade lasagna with marinara" class="image-band__img" loading="lazy" />
  </div>

  <section class="cta-band section--tight">
    <div class="container" style="text-align: center;">
      <p class="cta-band__text reveal">Ready to join us?</p>
      <a href="tel:7249423904" class="btn reveal">Call for Reservations</a>
    </div>
  </section>

</Layout>

<style>
  /* Menu hero */
  .menu-hero {
    padding-top: calc(var(--space-3xl) + 80px);
    padding-bottom: var(--space-xl);
    text-align: center;
  }

  .menu-hero__title {
    font-size: clamp(3rem, 2.5rem + 4vw, 7rem);
    font-style: italic;
  }

  .menu-hero__sub {
    font-family: var(--font-body), system-ui, sans-serif;
    font-size: 0.85rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--color-accent);
    margin-top: var(--space-s);
  }

  .menu-hero .divider {
    margin-inline: auto;
  }

  .menu-hero__note {
    max-width: 500px;
    margin-inline: auto;
    font-size: 0.9rem;
    color: var(--color-text-muted);

    & a {
      color: var(--color-accent);
      text-decoration: underline;
      text-underline-offset: 3px;

      &:hover {
        color: var(--color-text);
      }
    }
  }

  /* Course sections */
  .menu-course {
    border-top: 1px solid var(--color-border);
  }

  .menu-course--warm {
    background: var(--color-bg-warm);
  }

  .course-header {
    text-align: center;
    margin-bottom: var(--space-xl);
  }

  .course-header__italian {
    display: block;
    font-family: var(--font-display), Georgia, serif;
    font-style: italic;
    font-size: clamp(0.9rem, 0.85rem + 0.25vw, 1.1rem);
    color: var(--color-accent);
    letter-spacing: 0.05em;
    margin-bottom: var(--space-xs);
  }

  .course-header h2 {
    font-size: clamp(1.75rem, 1.5rem + 1.5vw, 3rem);
  }

  .course-header__desc {
    font-size: 0.9rem;
    color: var(--color-text-muted);
    margin-top: var(--space-xs);
  }

  /* Menu items */
  .menu-items {
    display: grid;
    gap: var(--space-l);
    max-width: 600px;
    margin-inline: auto;
  }

  .menu-item {
    text-align: center;
  }

  .menu-item__name {
    font-family: var(--font-display), Georgia, serif;
    font-size: clamp(1.1rem, 1rem + 0.3vw, 1.35rem);
    font-weight: 400;
    letter-spacing: 0.03em;
    color: var(--color-text);
    margin-bottom: 0.3em;
  }

  .menu-item__desc {
    font-size: 0.9rem;
    color: var(--color-text-muted);
    line-height: 1.6;
  }

  /* Image bands */
  .image-band {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2px;
    background: var(--color-border);
  }

  .image-band--duo {
    grid-template-columns: repeat(2, 1fr);
  }

  .image-band__img {
    width: 100%;
    aspect-ratio: 4 / 3;
    object-fit: cover;
    display: block;
  }

  @media (max-width: 640px) {
    .image-band {
      grid-template-columns: 1fr;
    }

    .image-band--duo {
      grid-template-columns: 1fr;
    }
  }

  /* CTA band */
  .cta-band {
    border-top: 1px solid var(--color-border);
  }

  .cta-band__text {
    font-family: var(--font-display), Georgia, serif;
    font-style: italic;
    font-size: clamp(1.25rem, 1rem + 0.75vw, 1.75rem);
    margin-bottom: var(--space-m);
    color: var(--color-text-muted);
  }
</style>
