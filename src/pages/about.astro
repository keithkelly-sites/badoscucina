---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Our Story | Bado's Cucina" description="The story behind Bado's Cucina — owner Adam Bados brought his Calabrian Italian heritage and a hand-constructed wood-fired oven to McMurray, PA.">

  <section class="hero-about">
    <div class="hero-about__image-wrap">
      <img src="/images/adam-oven.jpg" alt="Adam Bados working at the wood-fired oven" class="hero-about__image" loading="eager" fetchpriority="high" />
      <div class="hero-about__overlay"></div>
    </div>
    <div class="hero-about__content container">
      <h1 class="reveal">Our Story</h1>
      <hr class="divider reveal" />
    </div>
  </section>

  <section class="story section">
    <div class="container--narrow">
      <div class="story__lead reveal">
        <p class="story__opening">
          Bado's Cucina was born from inspiration Adam Bados acquired during
          his ventures to Calabria, Italy, and his own personal vision and tastes.
        </p>
      </div>

      <div class="story__body reveal">
        <p>
          His goal: to bring authentic wood-fired oven cuisine to this region of
          the country. Pittsburgh and the surrounding areas have a rich heritage
          of diverse ethnic backgrounds, and Adam's personal heritage is no
          exception. He comes from a proud Italian family that is intimately
          familiar with wonderfully prepared authentic Italian dishes made with
          the best of ingredients.
        </p>
        <p>
          Bado's Cucina carries on this proud Italian tradition, and offers you
          a cordial invitation to enjoy the tastes that our chefs have prepared
          for you.
        </p>
      </div>
    </div>
  </section>

  <section class="oven-section">
    <div class="oven-section__grid container">
      <div class="oven-section__image-col reveal">
        <img src="/images/fire.jpg" alt="Flames burning inside the wood-fired oven" class="oven-section__fire" loading="lazy" />
      </div>
      <div class="oven-section__text-col reveal">
        <h2>The Oven</h2>
        <hr class="divider" />
        <p>
          Upon arrival you will find our dining room is both intimate and open
          to a hand-constructed wood-fired oven. Your seat will be in full view
          of all meals as they are prepared and delivered to our patrons.
        </p>
        <p>
          Often times, our menu will be inspired by meats, produce, and spices
          found at market that very morning.
        </p>
      </div>
    </div>
  </section>

  <section class="atmosphere section">
    <div class="container">
      <div class="atmosphere__grid">
        <div class="atmosphere__image-tall reveal">
          <img src="/images/interior-red.jpg" alt="Bado's Cucina interior with warm red walls and dark wood tables" loading="lazy" />
        </div>
        <div class="atmosphere__text reveal">
          <h2>The Room</h2>
          <hr class="divider" />
          <p>
            Warm Tuscan walls, string lights overhead, the glow of fire from the
            oven, and tables close enough to hear the crackle. This isn't a dining
            room designed to disappear. You're meant to feel every part of it.
          </p>
        </div>
        <div class="atmosphere__image-wide reveal">
          <img src="/images/dining-room.jpg" alt="Guests enjoying dinner at Bado's Cucina" loading="lazy" />
        </div>
      </div>
    </div>
  </section>

  <section class="cta-band section--tight">
    <div class="container" style="text-align: center;">
      <p class="cta-band__text reveal">Reservations recommended</p>
      <a href="tel:7249423904" class="btn reveal">Call 724.942.3904</a>
    </div>
  </section>

</Layout>

<style>
  /* Hero */
  .hero-about {
    position: relative;
    min-height: 70vh;
    display: flex;
    align-items: flex-end;
    padding-bottom: var(--space-2xl);
    overflow: hidden;
  }

  .hero-about__image-wrap {
    position: absolute;
    inset: 0;
  }

  .hero-about__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: 70% center;
  }

  .hero-about__overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to bottom,
      oklch(0.13 0.01 55 / 0.3) 0%,
      oklch(0.13 0.01 55 / 0.7) 60%,
      oklch(0.13 0.01 55 / 0.95) 100%
    );
  }

  .hero-about__content {
    position: relative;
    z-index: 1;
  }

  .hero-about h1 {
    font-size: clamp(3rem, 2.5rem + 4vw, 7rem);
    font-style: italic;
    color: var(--color-text);
  }

  /* Story section */
  .story__opening {
    font-family: var(--font-display), Georgia, serif;
    font-size: clamp(1.4rem, 1.2rem + 1vw, 2rem);
    font-style: italic;
    line-height: 1.5;
    color: var(--color-accent);
    margin-bottom: var(--space-xl);
  }

  .story__body {
    color: var(--color-text-muted);
    font-size: clamp(1rem, 0.95rem + 0.25vw, 1.15rem);
  }

  /* Oven section */
  .oven-section {
    background: var(--color-bg-warm);
    padding-block: var(--space-2xl);
  }

  .oven-section__grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-xl);
    align-items: center;
  }

  .oven-section__fire {
    width: 100%;
    aspect-ratio: 4 / 3;
    object-fit: cover;
    border: 1px solid var(--color-border);
  }

  .oven-section__text-col {
    color: var(--color-text-muted);

    & h2 {
      color: var(--color-text);
    }

    & p + p {
      margin-top: 1em;
    }
  }

  /* Atmosphere */
  .atmosphere__grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    grid-template-rows: auto auto;
    gap: var(--space-l);
  }

  .atmosphere__image-tall {
    grid-row: 1 / 3;

    & img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      border: 1px solid var(--color-border);
    }
  }

  .atmosphere__text {
    align-self: end;
    color: var(--color-text-muted);

    & h2 {
      color: var(--color-text);
    }
  }

  .atmosphere__image-wide {
    & img {
      width: 100%;
      aspect-ratio: 16 / 10;
      object-fit: cover;
      border: 1px solid var(--color-border);
    }
  }

  /* CTA band */
  .cta-band {
    border-top: 1px solid var(--color-border);
  }

  .cta-band__text {
    font-family: var(--font-display), Georgia, serif;
    font-style: italic;
    font-size: clamp(1.25rem, 1rem + 0.75vw, 1.75rem);
    margin-bottom: var(--space-m);
    color: var(--color-text-muted);
  }

  @media (max-width: 768px) {
    .oven-section__grid {
      grid-template-columns: 1fr;
    }

    .atmosphere__grid {
      grid-template-columns: 1fr;
    }

    .atmosphere__image-tall {
      grid-row: auto;
    }
  }
</style>
